<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FFF1DA, Dark=#130F0C}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FFF9EF, Dark=#0F1711}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22" Spacing="16">

            <Border StrokeThickness="1" Stroke="#A95517" Padding="14" BackgroundColor="{AppThemeBinding Light=#FFFDF8, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Label Text="🎓" FontSize="26" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="MMU COURSEWORK DELIVERABLE" FontSize="11" FontAttributes="Bold" TextColor="#A95517" CharacterSpacing="1"/>
                        <Label Text="Developer: Wang Aicheng" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"/>
                        <Label Text="Student ID: 21906388 | Module: 6G6Z0014" FontSize="13" TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border StrokeThickness="1" Stroke="#007AFF" Padding="14" BackgroundColor="{AppThemeBinding Light=#F2F7FF, Dark=#111C30}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="Theme Mode Manager" FontSize="16" FontAttributes="Bold" TextColor="#007AFF" />
                        <Label Text="Manually override light and dark contrast layers instantly." FontSize="12" TextColor="{AppThemeBinding Light=#556D8B, Dark=#A9C2E3}" />
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Label Text="🌙 Dark Mode" FontSize="13" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"/>
                        <Switch x:Name="LocalThemeSwitch" VerticalOptions="Center" Toggled="OnLocalThemeSwitchToggled" SemanticProperties.Hint="Toggle app theme between light and dark style patterns"/>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Food Capture System" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                            <Label Text="Capture the real-time condition of the culinary item." FontSize="13" TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Photo"
                                BackgroundColor="#D9472B"
                                TextColor="#FFFFFF"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open native device camera to capture food imagery" />
                    </Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#312316}"
                            HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image x:Name="FoodPhoto"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Captured food preview frame" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="GPS Geolocation Services" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                            <Label Text="Acquire fine location coordinates and reverse geocoding." FontSize="13" TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Locate"
                                BackgroundColor="#2F7A4F"
                                TextColor="#FFFFFF"
                                Clicked="OnGetLocationClicked"
                                SemanticProperties.Hint="Invoke GPS hardware to fetch current meal position" />
                    </Grid>
                    <Label x:Name="LocationLabel"
                           Grid.Row="1"
                           Text="Location telemetry offline."
                           FontSize="14"
                           FontAttributes="Italic"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                    <Label x:Name="CoordinateLabel"
                           Grid.Row="2"
                           Text="Coordinates: Pending..."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Text-to-Speech Synthesis" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#F29B38, Dark=#FFB15D}" />
                    <Label Text="Convert system assets or custom user inputs into spoken audio streams." FontSize="13" TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />

                    <Entry x:Name="CustomNoteEntry"
                           Placeholder="Type a custom note or recipe name here..."
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                           PlaceholderColor="Gray"
                           Margin="0,4,0,0" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="🔊 Read Note"
                                BackgroundColor="#F29B38"
                                TextColor="#3A2518"
                                Clicked="OnReadCustomNoteClicked"
                                SemanticProperties.Hint="Read the custom inputted text aloud" />
                        <Button Grid.Column="1"
                                Text="📖 Read Help"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                                BorderColor="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                                BorderWidth="1"
                                TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFB15D}"
                                Clicked="OnReadHelpClicked"
                                SemanticProperties.Hint="Read the default application overview text aloud" />
                    </Grid>

                    <Button Text="⏹️ Stop Speech Engine"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                            BorderColor="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                            BorderWidth="1"
                            TextColor="#D9472B"
                            Clicked="OnStopSpeechClicked"
                            SemanticProperties.Hint="Abort all active audio synthesis streams" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="#007AFF"
                    BackgroundColor="{AppThemeBinding Light=#F2F7FF, Dark=#111C30}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🔄" FontSize="18" VerticalOptions="Center"/>
                        <Label Text="Motion Sensor Gamification" FontSize="17" FontAttributes="Bold" TextColor="#007AFF" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Utilizes device accelerometer to sense physical shaking events." FontSize="13" TextColor="{AppThemeBinding Light=#556D8B, Dark=#A9C2E3}" />
                    <BoxView HeightRequest="1" Color="#007AFF" Opacity="0.2" Margin="0,4"/>
                    <Label x:Name="ShakeStatusLabel" 
                           Text="Device Motion Stable. Shake phone to trigger recommendation." 
                           FontSize="14" 
                           HorizontalOptions="Center" 
                           HorizontalTextAlignment="Center"
                           FontAttributes="Bold" 
                           TextColor="#FF9500" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Execute Haptic Test"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    BorderColor="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
                    Clicked="OnFeedbackClicked"
                    SemanticProperties.Hint="Fire native vibration alerts and mechanical haptic pulses" />

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#312316}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="HardwareStatusLabel"
                           Text="Hardware Service Layer Online."
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" />
                    <Label x:Name="FeedbackCountLabel"
                           Text="Haptic Feedback Verification Cycles: 0"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings">
	<ScrollView>
		<ScrollView.Background>
			<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
				<GradientStop Color="{AppThemeBinding Light=#FFF1DA, Dark=#130F0C}" Offset="0.0" />
				<GradientStop Color="{AppThemeBinding Light=#FFF9EF, Dark=#0F1711}" Offset="1.0" />
			</LinearGradientBrush>
		</ScrollView.Background>

		<VerticalStackLayout Padding="22" Spacing="16">

			<Border StrokeThickness="1" Stroke="#A95517" Padding="14" BackgroundColor="{AppThemeBinding Light=#FFF4E5, Dark=#251B12}">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8" />
				</Border.StrokeShape>
				<Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
					<Label Text="🎓" FontSize="26" VerticalOptions="Center"/>
					<VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
						<Label Text="MMU Coursework Deliverable" FontSize="11" FontAttributes="Bold" TextColor="#A95517" CharacterSpacing="1"/>
						<Label Text="Developer: Wang Aicheng" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"/>
						<Label Text="Student ID: 21906388 | Module: 6G6Z0014" FontSize="13" TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}"/>
					</VerticalStackLayout>
				</Grid>
			</Border>

			<Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFDF8, Dark=#1A1712}">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="6">
					<Label Text="Accessibility Layers"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                           SemanticProperties.HeadingLevel="Level1" />
					<Label Text="Large text rules are evaluated instantly and propagated actively between application view containers."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
				</VerticalStackLayout>
			</Border>

			<Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="16">
					<Grid RowDefinitions="Auto,Auto" RowSpacing="8">
						<Label Text="UI Style Token Management"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
						<Picker x:Name="ThemePicker"
                                Grid.Row="1"
                                Title="Select Active Stylesheet"
                                SelectedIndexChanged="OnThemeChanged"
                                SemanticProperties.Hint="Alters dynamic application theme dictionary light or dark bindings manually">
							<Picker.Items>
								<x:String>Sync with Native OS Shell Theme</x:String>
								<x:String>Enforce Light Emulation Theme</x:String>
								<x:String>Enforce Dark High Contrast Theme</x:String>
							</Picker.Items>
						</Picker>
					</Grid>

					<BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

					<Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
						<VerticalStackLayout Spacing="4">
							<Label Text="Enlarged Content Matrix"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
							<Label Text="Dynamically scales component typography boundaries for evaluation."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
						</VerticalStackLayout>
						<Switch x:Name="LargeTextSwitch"
                                Grid.Column="1"
                                Toggled="OnLargeTextToggled"
                                SemanticProperties.Hint="Fires layout engine reflow to increase readability targets globally" />
					</Grid>
				</VerticalStackLayout>
			</Border>

			<Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#312316}"
                    Padding="16">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="8">
					<Label x:Name="LargeTextPreviewTitle"
                           Text="Live Layout Preview"
                           FontSize="19"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" />
					<Label x:Name="LargeTextPreviewBody"
                           Text="Activating this core state propagates structural changes to the inventory view systems instantly."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
				</VerticalStackLayout>
			</Border>

			<Label x:Name="SettingsStatusLabel"
                   Text="Preference Configuration Bridge Verified."
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}" />
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
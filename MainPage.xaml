<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodExplorer.MainPage"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}">
    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

            <Label Text="🍔 Food Explorer" 
                   FontSize="32" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="Log your culinary journeys and discover local dining spots"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <Label Text="💡 Tip: Shake your device for a random food suggestion!"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#007AFF"
                   FontAttributes="Italic"
                   Margin="0,10,0,20"/>

            <Button x:Name="CameraBtn"
                    Text="📷 Snap a Photo"
                    SemanticProperties.Description="Click to open the camera and take a photo of your meal"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnCameraBtnClicked" />

            <Button x:Name="LocationBtn"
                    Text="📍 Find Nearby Restaurants"
                    SemanticProperties.Description="Click to get your current location coordinates"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnLocationBtnClicked" />

            <Entry x:Name="FoodNoteEntry"
                   Placeholder="Type a food note or recipe name..."
                   SemanticProperties.Description="Enter text here to be read aloud"
                   Margin="0,20,0,0" />

            <Button x:Name="SpeakBtn"
                    Text="🔊 Read Note Aloud"
                    SemanticProperties.Description="Click to read the entered text aloud"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnSpeakBtnClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>